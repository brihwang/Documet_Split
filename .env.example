# AI is optional. The app uses local rules first and only calls AI for mixed-category PDFs.
# Keep AI_PROVIDER=rules for no AI. Use AI_PROVIDER=llmgateway for the gateway architecture.

# Hosted: https://api.llmgateway.io/v1
# Self-hosted: use the base URL from your deployment.
AI_PROVIDER=rules
LLM_GATEWAY_API_KEY=
LLM_GATEWAY_BASE_URL=https://api.llmgateway.io/v1
LLM_GATEWAY_MODEL=openai/gpt-4o-mini

MIN_CONFIDENCE=0.70
